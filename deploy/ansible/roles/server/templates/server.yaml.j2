# Auto-generated by Ansible — do not edit manually
default_lang: {{ default_lang }}
port: {{ batchalign_port }}
warmup: {{ warmup | lower }}
job_ttl_days: {{ job_ttl_days }}
max_concurrent_jobs: {{ max_concurrent_jobs | default(2) }}

{% if media_roots is defined %}
media_roots:
{% for root in media_roots %}
  - {{ root }}
{% endfor %}
{% elif not is_media_server | default(false) %}
media_roots:
  - /Volumes/TalkBank/media
{% else %}
media_roots: []
{% endif %}

{% if media_mappings is defined %}
media_mappings:
{% for key, path in media_mappings.items() %}
  {{ key }}: {{ path }}
{% endfor %}
{% elif client_media_mappings is defined and not is_media_server | default(false) %}
media_mappings:
{% for key, path in client_media_mappings.items() %}
  {{ key }}: {{ path }}
{% endfor %}
{% else %}
media_mappings: {}
{% endif %}

{% if redis_url is defined %}
redis_url: {{ redis_url }}
{% endif %}
